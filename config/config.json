{
  "api": {
    "base_url": "https://api.usaspending.gov/api/v2",
    "timeout_seconds": 30,
    "connect_timeout_seconds": 10,
    "read_timeout_seconds": 180,
    "max_retries": 5,
    "retry_delay_seconds": 2.0,
    "retry_backoff_multiplier": 2.0,
    "retry_max_delay_seconds": 30.0,
    "retry_jitter_seconds": 1.0,
    "page_pause_seconds": 5.0,
    "page_limit": 50
  },
  "workflow": {
    "company_names_excel": "config/CompanyNames.xlsx",
    "parent_companies_csv": "output/usaspending/parent_companies_ueis_duns.csv",
    "child_companies_csv": "output/usaspending/child_companies_duns_ueis.csv",
    "hierarchy_csv": "output/usaspending/company_hierarchy.csv",
    "awards_csv": "output/usaspending/usaspending_awards_by_uei.csv",
    "entity_master_csv": "output/usaspending/entity_master.csv",
    "relationships_csv": "output/usaspending/relationships.csv",
    "award_fact_csv": "output/usaspending/award_fact.csv",
    "failed_award_requests_csv": "output/usaspending/failed_award_requests.csv",
    "award_request_log_csv": "output/usaspending/award_request_log.csv",
    "award_progress_csv": "output/usaspending/award_progress.csv",
    "run_log_csv": "logs/run_log.csv",
    "powerbi_output_dir": "output/powerbi",
    "powerbi_entity_master_csv": "entity_master.csv",
    "award_fact_readable_csv": "award_fact_readable.csv",
    "relationships_readable_csv": "relationships_readable.csv",
    "parent_search_max_pages": 1,
    "fuzzy_mode": "strict",
    "fuzzy_threshold": 96.0,
    "fuzzy_min_gap": 12.0,
    "fuzzy_top_k": 3,
    "throttle_after_n_ueis": 3,
    "throttle_pause_seconds": 15,
    "start_date": "2025-01-01",
    "end_date": "now",
    "award_date_chunk": "quarter"
  },
  "fields": {
    "awards": [
      "Award ID",
      "Recipient Name",
      "recipient_id",
      "Recipient UEI",
      "Start Date",
      "End Date",
      "Award Amount",
      "Awarding Agency",
      "Awarding Sub Agency"
    ]
  },
  "analysis": {
    "default_company_name": ""
  }
}

